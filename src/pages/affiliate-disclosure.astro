---
import BaseLayout from '../layouts/BaseLayout.astro';
import { webPage, breadcrumbList } from '../lib/schema';

const jsonLd = [
  {
    ...webPage({
      name: 'Affiliate Disclosure',
      description: 'StackPractices affiliate disclosure and advertising policy.',
      url: '/affiliate-disclosure',
      locale: 'en',
    }),
    datePublished: '2026-06-10',
  },
  breadcrumbList([
    { name: 'Home', url: '/' },
    { name: 'Affiliate Disclosure', url: '/affiliate-disclosure' },
  ]),
];
---

<BaseLayout
  title="Affiliate Disclosure"
  description="StackPractices affiliate disclosure and advertising policy."
  path="/affiliate-disclosure"
  keywords={['affiliate disclosure', 'advertising', 'partnerships']}
  jsonLd={jsonLd}
>
  <div class="h-[3px] bg-gradient-to-r from-brand-500 via-brand-400 to-transparent"></div>

  <header class="border-b border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-3xl px-4 py-8 sm:px-6">
      <nav aria-label="Breadcrumb" class="text-sm text-slate-500">
        <a href="/" class="font-medium text-brand-600 hover:text-brand-700 hover:underline">Home</a>
        <span class="mx-2 text-slate-400">/</span>
        <span class="font-medium text-slate-800">Affiliate Disclosure</span>
      </nav>
      <h1 class="mt-4 text-3xl font-bold text-slate-900">Affiliate Disclosure</h1>
    </div>
  </header>

  <section class="bg-white">
    <div class="prose prose-slate mx-auto max-w-3xl px-4 py-10 sm:px-6">
      <div class="space-y-6 text-slate-700">
        <p>
          StackPractices is committed to complete transparency about how we generate revenue.
          This page explains affiliate links, advertising, donations, and partnerships in detail.
        </p>

        <h2 class="mt-10 text-xl font-semibold text-slate-900">Affiliate Links</h2>
        <p>
          Some articles on StackPractices may contain affiliate links to products, services, or tools
          we genuinely recommend. If you click an affiliate link and make a purchase, we may receive a
          small commission — <strong>at no additional cost to you</strong>. The price you pay remains
          exactly the same.
        </p>
        <p>
          Affiliate partnerships help us keep StackPractices free and actively maintained while
          continuing to produce high-quality, practical content for developers.
        </p>
        <p>
          We only recommend products and services that we have evaluated and believe are valuable to
          our audience. Our editorial content is entirely independent; affiliate relationships do not
          influence what we write about or the opinions we express.
        </p>

        <h2 class="mt-10 text-xl font-semibold text-slate-900">Advertising</h2>
        <p>
          StackPractices may display advertisements (for example, through Google AdSense or similar
          ad networks) on certain pages. Advertisements are clearly distinguishable from editorial
          content and labeled as such where required.
        </p>
        <p>
          Ad networks may use cookies to serve ads based on your browsing history. You can manage
          ad personalization through your browser settings or via the
          <a href="https://adssettings.google.com" class="text-brand-600 hover:underline" target="_blank" rel="noopener noreferrer">Google Ads Settings</a> page.
        </p>

        <h2 class="mt-10 text-xl font-semibold text-slate-900">Ko-fi Donations</h2>
        <p>
          We accept voluntary donations through Ko-fi. These contributions help keep the content free
          and growing. Donations do not influence editorial decisions.
        </p>

        <h2 class="mt-10 text-xl font-semibold text-slate-900">FTC Compliance and Transparency</h2>
        <p>
          In compliance with the U.S. Federal Trade Commission (FTC) guidelines and similar regulations
          in other jurisdictions, we disclose our affiliate relationships clearly. Affiliate links are
          identified where possible, and this disclosure page is linked from our footer and About page.
        </p>
        <p>
          If you have any questions about our partnerships, feel free to
          <a href="/contact/" class="text-brand-600 hover:underline">contact us</a>.
        </p>

        <p class="mt-10 text-sm text-slate-500">Last updated: June 10, 2026</p>
      </div>
    </div>
  </section>
</BaseLayout>
