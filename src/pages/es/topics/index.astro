---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { breadcrumbList, collectionPage } from '../../../lib/schema';
import { TECHNOLOGIES } from '../../../config/site';
import { getCollection } from 'astro:content';
import { isSpanish } from '../../../lib/content';

const concepts = [
  { slug: 'data', icon: '\u{1F4CA}', desc: 'Estructuras de datos, parsing, serialización y transformación.' },
  { slug: 'api', icon: '\u{1F50C}', desc: 'REST, GraphQL y patrones de diseño de API para integraciones robustas.' },
  { slug: 'authentication', icon: '\u{1F512}', desc: 'JWT, OAuth, gestión de sesiones y flujos de autenticación seguros.' },
  { slug: 'file-handling', icon: '\u{1F4C1}', desc: 'Lectura, escritura y manipulación de archivos en varios lenguajes.' },
  { slug: 'testing', icon: '\u{1F9EA}', desc: 'Estrategias de testing unitario, de integración y end-to-end.' },
  { slug: 'architecture', icon: '\u{1F3D7}', desc: 'Diseño de sistemas, microservicios y patrones escalables.' },
  { slug: 'design', icon: '\u{1F3A8}', desc: 'Principios de diseño de software, SOLID y arquitectura limpia.' },
  { slug: 'devops', icon: '\u{2699}', desc: 'CI/CD, contenedores, despliegue e infraestructura como código.' },
  { slug: 'databases', icon: '\u{1F5C4}', desc: 'SQL, NoSQL, ORMs y técnicas de modelado de datos.' },
  { slug: 'ai', icon: '\u{1F916}', desc: 'LLMs, embeddings, búsqueda vectorial y patrones de integración con IA.' },
  { slug: 'frontend', icon: '\u{1F4BB}', desc: 'Rendimiento web, gestión de estado, accesibilidad y patrones de UI.' },
  { slug: 'infrastructure', icon: '\u{1F6E0}', desc: 'Plataformas cloud, networking, balanceo de carga y service mesh.' },
  { slug: 'messaging', icon: '\u{1F4E8}', desc: 'Colas de mensajes, buses de eventos, pub/sub y procesamiento de streams.' },
  { slug: 'observability', icon: '\u{1F441}', desc: 'Métricas, logging, tracing y monitoreo para sistemas en producción.' },
  { slug: 'graphql', icon: '\u{1F310}', desc: 'Schemas, resolvers, federación y diseño de APIs GraphQL.' },
  { slug: 'serverless', icon: '\u{2601}', desc: 'Funciones, servicios gestionados, FaaS y computación orientada a eventos.' },
  { slug: 'caching', icon: '\u{26A1}', desc: 'Almacenamiento en memoria, CDN, estrategias de invalidación de caché.' },
  { slug: 'performance', icon: '\u{1F4C8}', desc: 'Profiling, optimización y técnicas de reducción de latencia.' },
  { slug: 'security', icon: '\u{1F6E1}', desc: 'Encriptación, escaneo de vulnerabilidades y prácticas de código seguro.' },
  { slug: 'concurrency', icon: '\u{1F300}', desc: 'Programación asíncrona, threading y procesamiento paralelo.' },
];


const [recipes, patterns, docs, guides] = await Promise.all([
  getCollection('recipes', e => isSpanish(e.id)),
  getCollection('patterns', e => isSpanish(e.id)),
  getCollection('docs', e => isSpanish(e.id)),
  getCollection('guides', e => isSpanish(e.id)),
]);

const allEntries = [...recipes, ...patterns, ...docs, ...guides];

function countByTopic(topic: string) {
  return allEntries.filter(e => e.data.topics.includes(topic as never)).length;
}

const jsonLd = [
  collectionPage({
    name: 'Temas',
    description: 'Explora contenido de StackPractices por tema y tecnología.',
    url: '/es/topics',
    locale: 'es',
    items: concepts.map((c) => ({ name: c.slug, url: `/es/topics/${c.slug}` })),
  }),
  breadcrumbList([
    { name: 'Inicio', url: '/es' },
    { name: 'Temas', url: '/es/topics' },
  ]),
];
---

<BaseLayout
  title="Temas"
  description="Explora recetas de código, patrones, documentos y guías por tema y tecnología."
  path="/es/topics"
  locale="es"
  keywords={['temas de programación', 'temas de tecnología', 'ingeniería de software']}
  jsonLd={jsonLd}
>
  <div class="h-[3px] bg-gradient-to-r from-brand-500 via-brand-400 to-transparent"></div>

  <header class="border-b border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
      <nav aria-label="Breadcrumb" class="text-sm text-slate-500">
        <a href="/es" class="font-medium text-brand-600 hover:text-brand-700 hover:underline">Inicio</a>
        <span class="mx-2 text-slate-400">/</span>
        <span class="font-medium text-slate-800">Temas</span>
      </nav>
      <h1 class="mt-4 text-4xl font-bold text-slate-900">Temas</h1>
      <p class="mt-3 max-w-2xl text-lg text-slate-600">
        Explora nuestros recursos prácticos organizados por concepto de ingeniería de software o tecnología de programación.
      </p>
    </div>
  </header>

  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
      <h2 class="text-2xl font-bold text-slate-900">Explorar por Concepto</h2>
      <p class="mt-2 text-slate-600">Descubre contenido organizado en torno a temas centrales de ingeniería de software.</p>

      <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {concepts.map((concept) => {
          const count = countByTopic(concept.slug);
          const s = concept.slug;
          const icon = s === 'data' ? (
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="10" width="4" height="6"/><rect x="10" y="6" width="4" height="10"/><rect x="16" y="2" width="4" height="14"/></svg>
          ) : s === 'api' ? (
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
          ) : s === 'authentication' ? (
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          ) : s === 'file-handling' ? (
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
          ) : s === 'testing' ? (
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          ) : s === 'architecture' ? (
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="3" x2="21" y1="9" y2="9"/><line x1="9" x2="9" y1="21" y2="9"/></svg>
          ) : s === 'design' ? (
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.5 8.6"/></svg>
          ) : s === 'devops' ? (
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><circle cx="12" cy="12" r="8"/></svg>
          ) : (
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
          );
          return (
            <a
              href={`/es/topics/${concept.slug}`}
              class="group relative flex flex-col rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-brand-400 hover:shadow-lg"
            >
              <div class="flex items-start gap-4">
                <span class="grid h-10 w-10 shrink-0 place-items-center rounded-lg bg-slate-800 text-white">
                  {icon}
                </span>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center justify-between gap-2">
                    <h3 class="text-base font-semibold text-slate-900 capitalize group-hover:text-brand-600">
                      {concept.slug.replace(/-/g, ' ')}
                    </h3>
                    <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-semibold text-slate-600">
                      {count}
                    </span>
                  </div>
                  <p class="mt-1 text-sm leading-relaxed text-slate-500">{concept.desc}</p>
                </div>
              </div>
              <div class="mt-3 flex items-center text-sm font-medium text-brand-600">
                Explorar
                <svg class="ml-1.5 h-4 w-4 transition group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="border-t border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
      <h2 class="text-2xl font-bold text-slate-900">Explorar por Tecnología</h2>
      <p class="mt-2 text-slate-600">Encuentra recursos para tu lenguaje o herramienta preferida.</p>

      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {TECHNOLOGIES.map((tech) => {
          const icon = tech === 'python' ? (
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2c-2.5 0-4 1.5-4 4v2H7c-2.5 0-4 1.5-4 4s1.5 4 4 4h3v-2c0-2.5 1.5-4 4-4h2V6c0-2.5-1.5-4-4-4z"/><path d="M12 22c2.5 0 4-1.5 4-4v-2h1c2.5 0 4-1.5 4-4s-1.5-4-4-4h-3v2c0 2.5-1.5 4-4 4H7v2c0 2.5 1.5 4 4 4z"/></svg>
          ) : tech === 'java' ? (
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9c0 3 2 5 6 5s6-2 6-5"/><path d="M12 14v4"/><path d="M8 22h8"/></svg>
          ) : tech === 'javascript' ? (
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 17v-5"/><path d="M12 17v-1a2 2 0 0 1 2-2h0"/></svg>
          ) : tech === 'typescript' ? (
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 17v-5"/><path d="M12 17v-1a2 2 0 0 1 2-2h0"/><line x1="16" x2="18" y1="12" y2="12"/></svg>
          ) : tech === 'sql' ? (
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
          ) : tech === 'bash' ? (
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M8 10l3 3-3 3"/><path d="M13 16h4"/></svg>
          ) : tech === 'docker' ? (
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="10" width="4" height="6"/><rect x="10" y="10" width="4" height="6"/><rect x="16" y="10" width="4" height="6"/><rect x="7" y="4" width="4" height="6"/><rect x="13" y="4" width="4" height="6"/><path d="M2 16h20"/></svg>
          ) : tech === 'git' ? (
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="12" r="3"/><path d="M6 9v6"/><path d="M9 6h3a3 3 0 0 1 3 3v3"/></svg>
          ) : (
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
          );
          return (
            <div class="flex items-center gap-4 rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-brand-400 hover:shadow-md">
              <span class="grid h-10 w-10 shrink-0 place-items-center rounded-lg bg-slate-800 text-white">
                {icon}
              </span>
              <div>
                <h3 class="text-base font-semibold capitalize text-slate-900">{tech}</h3>
                <p class="mt-0.5 text-xs text-slate-500">Ejemplos de código y guías</p>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
