---
import { getCollection } from 'astro:content';
import ListingPage from '../../../components/ListingPage.astro';
import { isSpanish } from '../../../lib/content';
import { topicIntros } from '../../../data/topic-intros';

export async function getStaticPaths() {
  const collections = await Promise.all([
    getCollection('recipes'),
    getCollection('patterns'),
    getCollection('docs'),
    getCollection('guides'),
  ]);

  const topics = new Set<string>();
  const enTopics = new Set<string>();
  for (const col of collections) {
    for (const entry of col) {
      if (isSpanish(entry.id)) {
        entry.data.topics.forEach((t: string) => topics.add(t));
      } else {
        entry.data.topics.forEach((t: string) => enTopics.add(t));
      }
    }
  }

  return Array.from(topics).map((topic) => ({ params: { topic }, props: { hasEnVersion: enTopics.has(topic) } }));
}

const { topic } = Astro.params;
const { hasEnVersion } = Astro.props;
const topicLabel = topic.replace(/-/g, ' ');
const intro = topicIntros[topic]?.es;

const [recipes, patterns, docs, guides] = await Promise.all([
  getCollection('recipes', ({ id }) => isSpanish(id)),
  getCollection('patterns', ({ id }) => isSpanish(id)),
  getCollection('docs', ({ id }) => isSpanish(id)),
  getCollection('guides', ({ id }) => isSpanish(id)),
]);

const entries = [...recipes, ...patterns, ...docs, ...guides]
  .filter((entry) => (entry.data.topics as string[]).some((t) => t === topic))
  .map((entry) => ({
    title: entry.data.title,
    description: entry.data.description,
    href: `/es/${entry.data.contentType}/${entry.data.slug}/`,
    difficulty: entry.data.difficulty,
    tags: entry.data.tags,
  }));
---

<ListingPage
  heading={topicLabel}
  description={`Recursos prácticos sobre ${topicLabel} para ingenieros de software.`}
  path={`/topics/${topic}/`}
  locale="es"
  entries={entries}
  keywords={[topicLabel, 'recetas', 'patrones', 'documentacion', 'guias']}
  hasAlternate={hasEnVersion}
>
  {intro && (
    <Fragment slot="intro">
      <section class="border-b border-slate-200 bg-white">
        <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
          <h2 class="text-xl font-semibold text-slate-900">{intro.heading}</h2>
          {intro.paragraphs.map((p) => (
            <p class="mt-3 max-w-3xl text-slate-600 leading-relaxed">{p}</p>
          ))}
        </div>
      </section>
    </Fragment>
  )}
</ListingPage>
