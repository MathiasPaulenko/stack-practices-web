---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { webPage, breadcrumbList } from '../../lib/schema';

const jsonLd = [
  {
    ...webPage({
      name: 'Acerca de StackPractices',
      description: 'Conoce StackPractices, una base de conocimiento práctica para ingenieros de software.',
      url: '/es/about',
      locale: 'es',
    }),
    datePublished: '2026-06-10',
  },
  breadcrumbList([
    { name: 'Inicio', url: '/es' },
    { name: 'Acerca de', url: '/es/about' },
  ]),
];
---

<BaseLayout
  title="Acerca de StackPractices"
  description="Conoce StackPractices, una base de conocimiento práctica para ingenieros de software."
  path="/about"
  locale="es"
  keywords={['acerca de', 'stackpractices', 'base de conocimiento']}
  jsonLd={jsonLd}
>
  <div class="h-[3px] bg-gradient-to-r from-brand-500 via-brand-400 to-transparent"></div>

  <!-- Header section -->
  <header class="border-b border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6">
      <nav aria-label="Breadcrumb" class="text-sm text-slate-500">
        <a href="/es" class="font-medium text-brand-600 hover:text-brand-700 hover:underline">Inicio</a>
        <span class="mx-2 text-slate-400">/</span>
        <span class="font-medium text-slate-800">Acerca de</span>
      </nav>
      <h1 class="mt-4 text-3xl font-bold text-slate-900">Acerca de StackPractices</h1>
      <p class="mt-2 max-w-2xl text-lg text-slate-600">
        Una base de conocimiento práctica para desarrolladores que quieren copiar, ejecutar y entregar más rápido.
      </p>
    </div>
  </header>

  <!-- Mission -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-lg leading-relaxed text-slate-700">
          StackPractices es una base de conocimiento práctica para ingenieros de software que buscan
          recetas de código reutilizables, patrones de diseño y plantillas de documentación en
          <strong>Python, Java, JavaScript, SQL y más</strong>.
        </p>
        <p class="mt-4 leading-relaxed text-slate-600">
          Cada recurso está diseñado para ser inmediatamente útil: copia el código, adapta a tu proyecto
          y entrega más rápido. Priorizamos ejemplos del mundo real sobre teoría abstracta, y cubrimos
          múltiples lenguajes para que encuentres la solución en el stack que usas hoy.
        </p>
      </div>
    </div>
  </section>

  <!-- Feature cards -->
  <section class="border-y border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
      <h2 class="text-2xl font-bold text-slate-900">Qué Encontrarás</h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2">
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:shadow-lg">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-slate-900">Recetas</h3>
          <p class="mt-1 text-sm text-slate-600">
            Soluciones cortas y accionables a problemas comunes de desarrollo. Copia, pega y adapta en minutos.
          </p>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:shadow-lg">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-slate-900">Patrones</h3>
          <p class="mt-1 text-sm text-slate-600">
            Patrones de diseño y arquitectura con implementaciones prácticas que puedes usar de inmediato.
          </p>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:shadow-lg">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-slate-900">Documentación</h3>
          <p class="mt-1 text-sm text-slate-600">
            Plantillas reutilizables para READMEs, docs de API, runbooks y otros artefactos de ingeniería.
          </p>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:shadow-lg">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-slate-900">Guías</h3>
          <p class="mt-1 text-sm text-slate-600">
            Contenido extenso que conecta recetas y patrones en flujos de trabajo cohesive y del mundo real.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Approach -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
      <div class="grid gap-10 lg:grid-cols-2">
        <div>
          <h2 class="text-2xl font-bold text-slate-900">Nuestro Enfoque</h2>
          <div class="mt-6 space-y-4 text-slate-700">
            <p>
              Creemos que la mejor documentación es aquella que puedes <strong>copiar, ejecutar y adaptar en minutos</strong>.
              Cada artículo incluye código en múltiples lenguajes, explicaciones claras y una sección de FAQ
              para referencia rápida.
            </p>
            <p>
              El contenido es <strong>bilingüe (inglés y español)</strong> para servir a la audiencia más amplia posible.
              Sin paywalls, sin suscripciones — solo conocimiento práctico que puedes usar hoy.
            </p>
          </div>
        </div>

        <div class="rounded-xl border border-slate-200 bg-slate-50 p-6">
          <h3 class="text-lg font-semibold text-slate-900">Construido Con</h3>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-sm font-medium text-slate-700">Astro</span>
            <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-sm font-medium text-slate-700">Tailwind CSS</span>
            <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-sm font-medium text-slate-700">Pagefind</span>
            <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-sm font-medium text-slate-700">TypeScript</span>
            <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-sm font-medium text-slate-700">GitHub Pages</span>
          </div>
          <p class="mt-4 text-sm text-slate-600">
            Open source y gratuito. Todo el sitio es estático — sin backend, sin base de datos, sin seguimiento
            más allá de análisis anónimos (con tu consentimiento).
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Funding -->
  <section class="border-y border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-2xl font-bold text-slate-900">Cómo nos Mantenemos</h2>
        <p class="mt-3 text-slate-600">
          StackPractices es gratuito. Sostenemos el proyecto a través de publicidad,
          colaboraciones de afiliados y el apoyo de la comunidad.
        </p>
      </div>
      <div class="mt-8 grid gap-6 sm:grid-cols-3">
        <div class="rounded-xl border border-slate-200 bg-white p-6 text-center">
          <div class="mx-auto flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          </div>
          <h3 class="mt-4 text-base font-semibold text-slate-900">Publicidad</h3>
          <p class="mt-1 text-sm text-slate-600">
            Anuncios relevantes y no intrusivos ayudan a cubrir los costos de hosting y creación de contenido.
          </p>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-6 text-center">
          <div class="mx-auto flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
          </div>
          <h3 class="mt-4 text-base font-semibold text-slate-900">Enlaces de Afiliados</h3>
          <p class="mt-1 text-sm text-slate-600">
            Algunas páginas incluyen enlaces de afiliados a herramientas que realmente recomendamos.
          </p>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-6 text-center">
          <div class="mx-auto flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.42 4.58a5.4 5.4 0 0 0-7.65 0l-.77.78-.77-.78a5.4 5.4 0 0 0-7.65 0 5.4 5.4 0 0 0 0 7.65l.77.78 7.65 7.65 7.65-7.65.77-.78a5.4 5.4 0 0 0 0-7.65Z"/></svg>
          </div>
          <h3 class="mt-4 text-base font-semibold text-slate-900">Donaciones</h3>
          <p class="mt-1 text-sm text-slate-600">
            Las contribuciones de la comunidad a través de Ko-fi mantienen el contenido gratuito y en crecimiento.
          </p>
        </div>
      </div>
      <p class="mt-8 text-center text-sm text-slate-500">
        Solo recomendamos productos y servicios que creemos valiosos para desarrolladores.
        Para más detalles, consulta nuestra <a href="/es/affiliate-disclosure" class="text-brand-600 hover:underline">Divulgación de Afiliados</a>.
      </p>
    </div>
  </section>

  <!-- Donation -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-6 text-center">
        <h2 class="text-lg font-semibold text-slate-900">Apoya a StackPractices</h2>
        <p class="mt-2 text-sm text-slate-600">
          Si encuentras útil este proyecto, considera invitarnos a un café. Tu apoyo ayuda a mantener el contenido gratuito y en crecimiento.
        </p>
        <a
          href="https://ko-fi.com/C6E4212B3X"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-block transition hover:scale-105 hover:brightness-110"
        >
          <img
            src="https://storage.ko-fi.com/cdn/kofi3.png?v=6"
            alt="Apóyanos en ko-fi.com"
            class="block h-12"
            loading="lazy"
          />
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
