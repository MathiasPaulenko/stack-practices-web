---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { webPage, breadcrumbList, person } from '../../lib/schema';

const jsonLd = [
  {
    ...webPage({
      name: 'Autores',
      description: 'Conoce a Mathias Vladimir Paulenko Echeverz, el ingeniero de software detrás de StackPractices — recetas de código, patrones de diseño y documentación de ingeniería.',
      url: '/es/authors/',
      locale: 'es',
    }),
    datePublished: '2026-06-13',
  },
  person({
    name: 'Mathias Vladimir Paulenko Echeverz',
    url: 'https://mathiaspaulenko.com',
    image: 'https://stackpractices.com/mathias-avatar.png',
    description: 'Ingeniero de software con más de 12 años de experiencia construyendo sistemas de producción con Python, JavaScript, React y DevOps.',
    jobTitle: 'Ingeniero de Software',
    sameAs: [
      'https://github.com/MathiasPaulenko',
      'https://cn.linkedin.com/in/mathias-paulenko-echeverz',
    ],
    knowsAbout: [
      'Software Engineering',
      'Python',
      'JavaScript',
      'React',
      'DevOps',
      'CI/CD',
      'API Design',
      'Cloud Infrastructure',
      'Full-Stack Development',
      'System Design',
    ],
  }),
  breadcrumbList([
    { name: 'Inicio', url: '/es/' },
    { name: 'Autores', url: '/es/authors/' },
  ]),
];
---

<BaseLayout
  title="Autores"
  description="Conoce a Mathias Vladimir Paulenko Echeverz, el ingeniero de software detrás de StackPractices."
  path="/authors/"
  keywords={['mathias paulenko', 'autor', 'ingeniero de software', 'stackpractices']}
  jsonLd={jsonLd}
  locale="es"
>
  <div class="h-[3px] bg-gradient-to-r from-brand-500 via-brand-400 to-transparent"></div>

  <header class="border-b border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6">
      <nav aria-label="Breadcrumb" class="text-sm text-slate-500">
        <a href="/es/" class="font-medium text-brand-600 hover:text-brand-700 hover:underline">Inicio</a>
        <span class="mx-2 text-slate-400">/</span>
        <span class="font-medium text-slate-800">Autores</span>
      </nav>
      <h1 class="mt-4 text-3xl font-bold text-slate-900">Sobre el Autor</h1>
      <p class="mt-2 max-w-2xl text-lg text-slate-600">
        La persona detrás de StackPractices — construyendo recursos prácticos para desarrolladores.
      </p>
    </div>
  </header>

  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
      <div class="mx-auto max-w-3xl">
        <div class="flex flex-col items-center gap-6 sm:flex-row sm:items-start">
          <img
            src="/mathias-avatar.png"
            alt="Mathias Vladimir Paulenko Echeverz"
            class="h-32 w-32 shrink-0 rounded-full object-cover ring-2 ring-brand-200"
            loading="lazy"
          />
          <div class="text-center sm:text-left">
            <h2 class="text-2xl font-bold text-slate-900">Mathias Vladimir Paulenko Echeverz</h2>
            <p class="mt-1 text-sm font-medium text-brand-600">Ingeniero de Software</p>
            <p class="mt-4 leading-relaxed text-slate-700">
              Ingeniero de software con más de <strong>12 años de experiencia</strong> construyendo
              sistemas de producción con <strong>Python, JavaScript, React y DevOps</strong>. He
              contribuido a proyectos empresariales que abarcan pipelines de CI/CD, diseño de APIs,
              infraestructura cloud y desarrollo full-stack.
            </p>
            <p class="mt-4 leading-relaxed text-slate-600">
              StackPractices es mi proyecto personal, nacido de una convicción simple:
              <strong>la buena documentación debe ser lista para copiar y pegar</strong>. Cada receta,
              patrón y guía de este sitio está diseñada para ahorrarte tiempo y ayudarte a
              entregar más rápido.
            </p>
            <div class="mt-6 flex flex-wrap justify-center gap-3 sm:justify-start">
              <a href="https://mathiaspaulenko.com" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 rounded-lg bg-white px-3 py-1.5 text-sm font-medium text-slate-700 ring-1 ring-slate-200 hover:text-brand-600 hover:ring-brand-300">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
                Sitio Web
              </a>
              <a href="https://github.com/MathiasPaulenko" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 rounded-lg bg-white px-3 py-1.5 text-sm font-medium text-slate-700 ring-1 ring-slate-200 hover:text-brand-600 hover:ring-brand-300">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                GitHub
              </a>
              <a href="https://cn.linkedin.com/in/mathias-paulenko-echeverz" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 rounded-lg bg-white px-3 py-1.5 text-sm font-medium text-slate-700 ring-1 ring-slate-200 hover:text-brand-600 hover:ring-brand-300">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
              <a href="mailto:mathias.paulenko@outlook.com" class="inline-flex items-center gap-1.5 rounded-lg bg-white px-3 py-1.5 text-sm font-medium text-slate-700 ring-1 ring-slate-200 hover:text-brand-600 hover:ring-brand-300">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                Correo
              </a>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-slate-900">Revisado por Pares</h3>
          <p class="mt-1 text-sm text-slate-600">
            Cada recurso es revisado por varios ingenieros antes de su publicación.
          </p>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-slate-900">Código Probado</h3>
          <p class="mt-1 text-sm text-slate-600">
            Los ejemplos de código se ejecutan y validan en entornos de desarrollo reales.
          </p>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-100 text-brand-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-slate-900">Actualizado Regularmente</h3>
          <p class="mt-1 text-sm text-slate-600">
            El contenido se mantiene al día con las últimas versiones de lenguajes y mejores prácticas.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
      <div class="max-w-3xl">
        <h2 class="text-2xl font-bold text-slate-900">Nuestro Proceso Editorial</h2>
        <ol class="mt-6 space-y-4 text-slate-700">
          <li class="flex gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-100 text-xs font-bold text-brand-700">1</span>
            <span><strong>Investigación</strong> — Identificamos problemas del mundo real que enfrentan los desarrolladores.</span>
          </li>
          <li class="flex gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-100 text-xs font-bold text-brand-700">2</span>
            <span><strong>Borrador</strong> — Escribimos explicaciones claras con ejemplos de código ejecutables.</span>
          </li>
          <li class="flex gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-100 text-xs font-bold text-brand-700">3</span>
            <span><strong>Revisión</strong> — Revisión técnica por expertos del dominio para garantizar precisión.</span>
          </li>
          <li class="flex gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-100 text-xs font-bold text-brand-700">4</span>
            <span><strong>Pruebas</strong> — Ejecutamos el código en múltiples entornos para verificar su corrección.</span>
          </li>
          <li class="flex gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-100 text-xs font-bold text-brand-700">5</span>
            <span><strong>Publicación y Mantenimiento</strong> — Publicamos y actualizamos a medida que evolucionan las tecnologías.</span>
          </li>
        </ol>
      </div>
    </div>
  </section>

  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
      <div class="max-w-3xl">
        <h2 class="text-2xl font-bold text-slate-900">Contacto</h2>
        <p class="mt-4 text-slate-600">
          ¿Tienes comentarios, correcciones o sugerencias? Me encantaría saber de ti.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/es/contact" class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-4 py-2 text-sm font-medium text-white hover:bg-brand-700">
            Contacto
          </a>
          <a href="/es" class="inline-flex items-center gap-2 rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:border-brand-400 hover:text-brand-700">
            Explorar Recetas
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
