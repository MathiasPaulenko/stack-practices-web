---
import { getCollection } from 'astro:content';
import ListingPage from '../../../components/ListingPage.astro';
import { isSpanish } from '../../../lib/content';

const recipes = await getCollection('recipes', ({ id, data }) => isSpanish(id) && !data.draft);
const entries = recipes.map((r) => ({
  title: r.data.title,
  description: r.data.description,
  href: `/es/recipes/${r.data.slug}`,
  difficulty: r.data.difficulty,
  tags: r.data.tags,
}));
---

<ListingPage
  heading="Recetas"
  description="Soluciones prácticas listas para copiar a problemas reales de desarrollo en varios lenguajes."
  path="/es/recipes"
  locale="es"
  entries={entries}
  keywords={['recetas de código', 'cómo', 'ejemplos de programación']}
  contentType="recipes"
/>
