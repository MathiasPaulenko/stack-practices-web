---
import { buildTagIndex } from '../../../lib/content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { webPage, breadcrumbList } from '../../../lib/schema';

const tagIndex = await buildTagIndex('es');
const sortedTags = Array.from(tagIndex.entries())
  .map(([tag, items]) => ({ tag, count: items.length }))
  .sort((a, b) => b.count - a.count || a.tag.localeCompare(b.tag));

const heading = 'Etiquetas';
const description = 'Explora todos los temas y tecnologías cubiertos en recetas, patrones, documentación y guías.';

const jsonLd = [
  webPage({ name: heading, description, url: '/es/tags', locale: 'es' }),
  breadcrumbList([
    { name: 'Inicio', url: '/es/' },
    { name: heading, url: '/es/tags/' },
  ]),
];
---

<BaseLayout title={heading} description={description} path="/tags/" locale="es" keywords={['etiquetas', 'temas', 'tecnologías', 'ingeniería de software']} jsonLd={jsonLd}>
  <section class="border-b border-slate-800 bg-slate-900">
    <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
      <nav aria-label="Breadcrumb" class="text-sm text-slate-400">
        <a href="/es/" class="font-medium text-brand-400 hover:text-brand-300">Inicio</a>
        <span class="mx-2 text-slate-600">/</span>
        <span class="font-medium text-slate-300">{heading}</span>
      </nav>
      <h1 class="mt-4 text-3xl font-bold text-white">{heading}</h1>
      <p class="mt-2 max-w-2xl text-slate-300">{description}</p>
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
      {
        sortedTags.length > 0 ? (
          <>
            <div class="relative max-w-md mb-8">
              <input
                type="text"
                id="tag-search"
                placeholder="Filtrar etiquetas..."
                class="w-full rounded-lg border border-slate-300 bg-white py-2.5 pl-10 pr-4 text-sm text-slate-900 placeholder:text-slate-400 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500/20"
              />
              <svg class="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
              </svg>
            </div>
            <p id="tag-count" class="mb-4 text-sm text-slate-500">{sortedTags.length} etiquetas</p>
            <div id="tag-grid" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {sortedTags.map(({ tag, count }, i) => (
                <a
                  href={`/es/tags/${tag}/`}
                  data-search={tag.toLowerCase()}
                  class="tag-card group flex items-center justify-between rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-brand-400 hover:shadow-md"
                  style={i >= 30 ? 'display:none' : undefined}
                >
                  <div class="flex items-center gap-3">
                    <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-brand-100 text-sm font-semibold text-brand-700">
                      {tag.charAt(0).toUpperCase()}
                    </span>
                    <span class="text-sm font-semibold text-slate-900 group-hover:text-brand-600">{tag}</span>
                  </div>
                  <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-600">
                    {count} {count === 1 ? 'recurso' : 'recursos'}
                  </span>
                </a>
              ))}
            </div>
            <div class="mt-8 text-center">
              <button
                id="load-more"
                type="button"
                class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-brand-700"
                style={sortedTags.length <= 30 ? 'display:none' : undefined}
              >
                Cargar más etiquetas
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </button>
            </div>
            <div id="tag-empty" class="hidden rounded-xl border border-dashed border-slate-300 bg-slate-100 p-12 text-center">
              <p class="text-slate-600">Ninguna etiqueta coincide con tu búsqueda.</p>
            </div>
          </>
        ) : (
          <div class="rounded-xl border border-dashed border-slate-300 bg-slate-100 p-12 text-center">
            <p class="text-slate-600">Aún no hay etiquetas. Vuelve pronto.</p>
          </div>
        )
      }
    </div>
  </section>

  <script is:inline>
    (function () {
      const PAGE_SIZE = 30;
      const input = document.getElementById('tag-search');
      const grid = document.getElementById('tag-grid');
      const count = document.getElementById('tag-count');
      const empty = document.getElementById('tag-empty');
      const loadMoreBtn = document.getElementById('load-more');
      if (!input || !grid || !count || !empty) return;

      const allCards = Array.from(grid.querySelectorAll('.tag-card'));
      let visibleCount = PAGE_SIZE;
      let isSearching = false;

      function showCards(cards) {
        cards.forEach((card, i) => {
          card.style.display = i < visibleCount ? '' : 'none';
        });
      }

      function update() {
        const query = input.value.trim().toLowerCase();
        isSearching = query.length > 0;
        let matched = 0;

        if (isSearching) {
          allCards.forEach((card) => {
            const index = card.getAttribute('data-search') || '';
            const match = index.includes(query);
            card.style.display = match ? '' : 'none';
            if (match) matched++;
          });
          if (loadMoreBtn) loadMoreBtn.style.display = 'none';
        } else {
          matched = allCards.filter(c => c.style.display !== 'none').length;
          showCards(allCards);
          if (loadMoreBtn) {
            loadMoreBtn.style.display = visibleCount < allCards.length ? '' : 'none';
          }
        }

        const label = matched === 1 ? ' etiqueta' : ' etiquetas';
        count.textContent = (isSearching ? matched : Math.min(visibleCount, allCards.length)) + label;

        const anyVisible = allCards.some(c => c.style.display !== 'none');
        if (!anyVisible) {
          grid.classList.add('hidden');
          empty.classList.remove('hidden');
        } else {
          grid.classList.remove('hidden');
          empty.classList.add('hidden');
        }
      }

      if (loadMoreBtn) {
        loadMoreBtn.addEventListener('click', () => {
          visibleCount += PAGE_SIZE;
          showCards(allCards);
          if (visibleCount >= allCards.length) {
            loadMoreBtn.style.display = 'none';
          }
          const label = visibleCount === 1 ? ' etiqueta' : ' etiquetas';
          count.textContent = visibleCount + label;
        });
      }

      input.addEventListener('input', update);
    })();
  </script>
</BaseLayout>
