---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { webPage } from '../../lib/schema';

const jsonLd = [
  webPage({
    name: 'Buscar',
    description: 'Busca recetas de código, patrones de diseño, documentación y guías en StackPractices.',
    url: '/es/search',
    locale: 'es',
  }),
];
---

<BaseLayout
  title="Buscar"
  description="Busca recetas de código, patrones de diseño, documentación y guías en StackPractices."
  path="/search"
  locale="es"
  jsonLd={jsonLd}
  noindex={true}
>
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <h1 class="text-3xl font-bold text-slate-900">Buscar</h1>
    <p class="mt-2 text-slate-600">Encuentra recetas, patrones, documentos y guías.</p>
    <div id="search" class="mt-8"></div>
  </section>

  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <style is:global>
    .pagefind-ui {
      --pagefind-ui-scale: 0.9;
      --pagefind-ui-primary: #2563eb;
      --pagefind-ui-text: #0f172a;
      --pagefind-ui-border: #e2e8f0;
      --pagefind-ui-tag: #f1f5f9;
    }
    .pagefind-ui .pagefind-ui__result {
      border-bottom: 1px solid var(--pagefind-ui-border);
      padding: 1rem 0;
    }
    .pagefind-ui .pagefind-ui__result-title {
      font-weight: 600;
      font-size: 1.1rem;
      color: #1e40af;
    }
    .pagefind-ui .pagefind-ui__result-excerpt {
      color: #475569;
      font-size: 0.95rem;
      line-height: 1.5;
    }
    .pagefind-ui .pagefind-ui__result-link {
      color: #2563eb;
      font-weight: 500;
    }
    .pagefind-ui .pagefind-ui__result-image,
    .pagefind-ui .pagefind-ui__result-thumb {
      display: none !important;
    }
    .pagefind-ui__result img,
    .pagefind-ui__result-excerpt img {
      display: none !important;
    }

    .pagefind-ui .pagefind-ui__filter-panel {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 1rem;
      border: 1px solid #e2e8f0;
      border-radius: 0.75rem;
      padding: 1.25rem;
      background: #f8fafc;
      margin-bottom: 1.5rem;
    }
    .pagefind-ui .pagefind-ui__filter-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .pagefind-ui .pagefind-ui__filter-label {
      font-weight: 600;
      font-size: 0.875rem;
      color: #1e293b;
      text-transform: none;
      letter-spacing: normal;
      margin-bottom: 0.25rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid #e2e8f0;
    }
    .pagefind-ui .pagefind-ui__filter-value {
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
    }
    .pagefind-ui .pagefind-ui__filter-value label {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.875rem;
      color: #475569;
      cursor: pointer;
      padding: 0.25rem 0.5rem;
      border-radius: 0.375rem;
      transition: background 0.15s;
    }
    .pagefind-ui .pagefind-ui__filter-value label:hover {
      background: #eff6ff;
      color: #1d4ed8;
    }
    .pagefind-ui .pagefind-ui__filter-value input[type="checkbox"] {
      appearance: none;
      -webkit-appearance: none;
      width: 1rem;
      height: 1rem;
      border: 1.5px solid #94a3b8;
      border-radius: 0.25rem;
      background: white;
      cursor: pointer;
      position: relative;
      flex-shrink: 0;
    }
    .pagefind-ui .pagefind-ui__filter-value input[type="checkbox"]:checked {
      background: #2563eb;
      border-color: #2563eb;
    }
    .pagefind-ui .pagefind-ui__filter-value input[type="checkbox"]:checked::after {
      content: "";
      position: absolute;
      left: 0.25rem;
      top: 0.125rem;
      width: 0.3rem;
      height: 0.55rem;
      border: solid white;
      border-width: 0 0.125rem 0.125rem 0;
      transform: rotate(45deg);
    }
    .pagefind-ui .pagefind-ui__filter-value input[type="checkbox"]:focus-visible {
      outline: 2px solid #2563eb;
      outline-offset: 2px;
    }

    /* Force filter accordions open — flat checkbox layout */
    .pagefind-ui .pagefind-ui__filter-group details {
      display: block !important;
    }
    .pagefind-ui .pagefind-ui__filter-group summary {
      list-style: none;
      cursor: default;
      pointer-events: none;
      padding: 0;
      margin: 0;
    }
    .pagefind-ui .pagefind-ui__filter-group summary::-webkit-details-marker,
    .pagefind-ui .pagefind-ui__filter-group summary::marker {
      display: none !important;
    }
    .pagefind-ui .pagefind-ui__filter-group details > summary::before,
    .pagefind-ui .pagefind-ui__filter-group details > summary::after {
      display: none !important;
    }
  </style>
  <script is:inline src="/pagefind/pagefind-ui.js" defer></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      if (window.PagefindUI) {
        const ui = new window.PagefindUI({
          element: '#search',
          showSubResults: true,
          showFilters: true,
          translations: {
            placeholder: 'Buscar...',
            clear_search: 'Limpiar',
            load_more: 'Cargar más resultados',
            search_label: 'Buscar en este sitio',
            filters_label: 'Filtros',
            zero_results: 'No se encontraron resultados para [SEARCH_TERM]',
            many_results: '[COUNT] resultados encontrados',
            one_result: 'Un resultado encontrado',
            alt_search: 'No se encontraron resultados para [SEARCH_TERM]. Mostrando resultados para [DIFFERENT_TERM] en su lugar.',
            search_suggestion: 'No se encontraron resultados para [SEARCH_TERM]. Intenta una de estas búsquedas:',
            searching: 'Buscando...'
          },
          processResult: function (result) {
            const typeMap = {
              'recipes': 'Receta',
              'patterns': 'Patrón',
              'docs': 'Doc',
              'guides': 'Guía'
            };
            const filters = result.filters || {};
            const contentType = (filters.contentType || [])[0] || '';
            const label = typeMap[contentType] || '';
            if (label && result.meta && result.meta.title) {
              result.meta.title = '[' + label + '] ' + result.meta.title;
            }
            return result;
          },
          filterConfig: {
            contentType: { label: 'Tipo de contenido' },
            lang: { label: 'Idioma' }
          }
        });

        function prettifyFilters() {
          const map = {
            'recipes': 'Recetas',
            'patterns': 'Patrones',
            'docs': 'Documentos',
            'guides': 'Guías',
            'en': 'Inglés',
            'es': 'Español'
          };
          document.querySelectorAll('.pagefind-ui__filter-value label, .pagefind-ui__filter-value span, .pagefind-ui__filter-value').forEach(el => {
            const key = el.textContent.trim().toLowerCase();
            if (map[key]) {
              const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null, false);
              let node;
              while (node = walker.nextNode()) {
                const text = node.textContent.trim();
                if (map[text.toLowerCase()]) {
                  node.textContent = node.textContent.replace(text, map[text.toLowerCase()]);
                }
              }
            }
          });
        }
        function expandFilters() {
          document.querySelectorAll('.pagefind-ui__filter-group details').forEach(d => {
            d.open = true;
          });
        }
        setTimeout(() => { prettifyFilters(); expandFilters(); }, 200);
        const searchEl = document.getElementById('search');
        if (searchEl) {
          const observer = new MutationObserver(() => { prettifyFilters(); expandFilters(); });
          observer.observe(searchEl, { childList: true, subtree: true });
        }
        const params = new URLSearchParams(window.location.search);
        const q = params.get('q');
        if (q) {
          setTimeout(() => ui.triggerSearch(q), 100);
        }
      }
    });
  </script>
</BaseLayout>
