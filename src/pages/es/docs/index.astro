---
import { getCollection } from 'astro:content';
import ListingPage from '../../../components/ListingPage.astro';
import { isSpanish } from '../../../lib/content';

const docs = await getCollection('docs', ({ id, data }) => isSpanish(id) && !data.draft);
const entries = docs.map((d) => ({
  title: d.data.title,
  description: d.data.description,
  href: `/es/docs/${d.data.slug}`,
  difficulty: d.data.difficulty,
  tags: d.data.tags,
}));
---

<ListingPage
  heading="Documentación"
  description="Plantillas de documentación técnica reutilizables: READMEs, ADRs, runbooks y más."
  path="/es/docs"
  locale="es"
  entries={entries}
  keywords={['plantillas de documentación', 'plantilla readme', 'plantilla adr']}
  contentType="docs"
/>
