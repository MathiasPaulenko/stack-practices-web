---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { breadcrumbList, collectionPage } from '../../lib/schema';
import { TECHNOLOGIES } from '../../config/site';
import { getCollection } from 'astro:content';
import { isSpanish } from '../../lib/content';

const concepts = [
  { slug: 'data', icon: '\u{1F4CA}', desc: 'Data structures, parsing, serialization, and transformation.' },
  { slug: 'api', icon: '\u{1F50C}', desc: 'REST, GraphQL, and API design patterns for robust integrations.' },
  { slug: 'authentication', icon: '\u{1F512}', desc: 'JWT, OAuth, session management, and secure auth flows.' },
  { slug: 'file-handling', icon: '\u{1F4C1}', desc: 'Reading, writing, and manipulating files across languages.' },
  { slug: 'testing', icon: '\u{1F9EA}', desc: 'Unit, integration, and end-to-end testing strategies.' },
  { slug: 'architecture', icon: '\u{1F3D7}', desc: 'System design, microservices, and scalable patterns.' },
  { slug: 'design', icon: '\u{1F3A8}', desc: 'Software design principles, SOLID, and clean architecture.' },
  { slug: 'devops', icon: '\u{2699}', desc: 'CI/CD, containers, deployment, and infrastructure as code.' },
  { slug: 'databases', icon: '\u{1F5C4}', desc: 'SQL, NoSQL, ORMs, and data modeling techniques.' },
];

const techIcons: Record<string, string> = {
  python: '\u{1F40D}',
  java: '\u{2615}',
  javascript: '\u{1F7E8}',
  typescript: '\u{1F537}',
  sql: '\u{1F5C3}',
  bash: '\u{1F5A5}',
  docker: '\u{1F433}',
  git: '\u{1F500}',
};

const [recipes, patterns, docs, guides] = await Promise.all([
  getCollection('recipes', e => !isSpanish(e.id)),
  getCollection('patterns', e => !isSpanish(e.id)),
  getCollection('docs', e => !isSpanish(e.id)),
  getCollection('guides', e => !isSpanish(e.id)),
]);

const allEntries = [...recipes, ...patterns, ...docs, ...guides];

function countByTopic(topic: string) {
  return allEntries.filter(e => e.data.topics.includes(topic as never)).length;
}

const jsonLd = [
  collectionPage({
    name: 'Topics',
    description: 'Browse StackPractices content by topic and technology.',
    url: '/topics',
    locale: 'en',
    items: concepts.map((c) => ({ name: c.slug, url: `/topics/${c.slug}` })),
  }),
  breadcrumbList([
    { name: 'Home', url: '/' },
    { name: 'Topics', url: '/topics' },
  ]),
];
---

<BaseLayout
  title="Topics"
  description="Browse code recipes, patterns, docs, and guides by topic and technology."
  path="/topics"
  keywords={['programming topics', 'technology topics', 'software engineering']}
  jsonLd={jsonLd}
>
  <div class="h-[3px] bg-gradient-to-r from-brand-500 via-brand-400 to-transparent"></div>

  <header class="border-b border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
      <nav aria-label="Breadcrumb" class="text-sm text-slate-500">
        <a href="/" class="font-medium text-brand-600 hover:text-brand-700 hover:underline">Home</a>
        <span class="mx-2 text-slate-400">/</span>
        <span class="font-medium text-slate-800">Topics</span>
      </nav>
      <h1 class="mt-4 text-4xl font-bold text-slate-900">Topics</h1>
      <p class="mt-3 max-w-2xl text-lg text-slate-600">
        Browse our practical resources organized by software engineering concept or programming technology.
      </p>
    </div>
  </header>

  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
      <h2 class="text-2xl font-bold text-slate-900">Browse by Concept</h2>
      <p class="mt-2 text-slate-600">Explore content organized around core software engineering themes.</p>

      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {concepts.map((concept) => {
          const count = countByTopic(concept.slug);
          return (
            <a
              href={`/topics/${concept.slug}`}
              class="group relative flex flex-col rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:border-brand-400 hover:shadow-lg"
            >
              <div class="flex items-start justify-between">
                <span class="grid h-12 w-12 place-items-center rounded-xl bg-brand-50 text-2xl">
                  {concept.icon}
                </span>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
                  {count} {count === 1 ? 'resource' : 'resources'}
                </span>
              </div>
              <h3 class="mt-5 text-lg font-semibold text-slate-900 capitalize group-hover:text-brand-600">
                {concept.slug.replace(/-/g, ' ')}
              </h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-500">{concept.desc}</p>
              <div class="mt-4 flex items-center text-sm font-medium text-brand-600">
                Explore
                <svg class="ml-1.5 h-4 w-4 transition group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="border-t border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
      <h2 class="text-2xl font-bold text-slate-900">Browse by Technology</h2>
      <p class="mt-2 text-slate-600">Find resources for your preferred programming language or tool.</p>

      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {TECHNOLOGIES.map((tech) => (
          <div class="flex items-center gap-4 rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-brand-400 hover:shadow-md">
            <span class="grid h-10 w-10 place-items-center rounded-lg bg-brand-50 text-xl">
              {techIcons[tech] || '\u{1F4BB}'}
            </span>
            <div>
              <h3 class="text-base font-semibold capitalize text-slate-900">{tech}</h3>
              <p class="mt-0.5 text-xs text-slate-500">Code examples & guides</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
