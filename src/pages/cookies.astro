---
import BaseLayout from '../layouts/BaseLayout.astro';
import { webPage, breadcrumbList } from '../lib/schema';

const jsonLd = [
  {
    ...webPage({
      name: 'Cookie Policy',
      description: 'How StackPractices uses cookies and similar technologies.',
      url: '/cookies',
      locale: 'en',
    }),
    datePublished: '2026-06-10',
  },
  breadcrumbList([
    { name: 'Home', url: '/' },
    { name: 'Cookie Policy', url: '/cookies' },
  ]),
];
---

<BaseLayout
  title="Cookie Policy"
  description="How StackPractices uses cookies and similar technologies."
  path="/cookies"
  keywords={['cookies', 'tracking', 'privacy']}
  jsonLd={jsonLd}
>
  <!-- Subtle brand accent line -->
  <div class="h-[3px] bg-gradient-to-r from-brand-500 via-brand-400 to-transparent"></div>

  <!-- Header section -->
  <header class="border-b border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-3xl px-4 py-8 sm:px-6">
      <nav aria-label="Breadcrumb" class="text-sm text-slate-500">
        <a href="/" class="font-medium text-brand-600 hover:text-brand-700 hover:underline">Home</a>
        <span class="mx-2 text-slate-400">/</span>
        <span class="font-medium text-slate-800">Cookie Policy</span>
      </nav>
      <h1 class="mt-4 text-3xl font-bold text-slate-900">Cookie Policy</h1>
    </div>
  </header>

  <!-- Main content -->
  <section class="bg-white">
    <div class="prose prose-slate mx-auto max-w-3xl px-4 py-10 sm:px-6">
      <div class="space-y-6 text-slate-700">
      <p>
        This policy explains how StackPractices uses cookies, localStorage, and similar technologies
        to store information on your device.
      </p>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">What Are Cookies</h2>
      <p>
        Cookies are small text files placed on your device by websites you visit. They are commonly
        used to make sites work efficiently, remember preferences, and provide anonymous analytics data
        to site owners. We also use <strong>localStorage</strong>, a similar browser technology, to save
        your cookie consent choice without sending data to a server.
      </p>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">Cookies and Technologies We Use</h2>
      <div class="overflow-x-auto">
        <table class="min-w-full text-left text-sm">
          <thead>
            <tr class="border-b border-slate-200">
              <th class="py-2 pr-4 font-semibold text-slate-900">Category</th>
              <th class="py-2 pr-4 font-semibold text-slate-900">Purpose</th>
              <th class="py-2 font-semibold text-slate-900">Duration</th>
            </tr>
          </thead>
          <tbody class="text-slate-600">
            <tr class="border-b border-slate-100">
              <td class="py-2 pr-4 font-medium">Essential</td>
              <td class="py-2 pr-4">Language preference, cookie consent state</td>
              <td class="py-2">Persistent (localStorage)</td>
            </tr>
            <tr class="border-b border-slate-100">
              <td class="py-2 pr-4 font-medium">Analytics</td>
              <td class="py-2 pr-4">Anonymous page views via Google Analytics</td>
              <td class="py-2">2 years (_ga), 24 hours (_gid)</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">Third-Party Cookies</h2>
      <p>
        Google Analytics may set cookies on your device to track anonymous usage patterns. These
        cookies are only placed after you provide consent via our cookie banner. You can revoke consent
        at any time by clearing cookies or using the controls below.
      </p>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">How to Manage Cookies</h2>
      <p>
        You can control, block, or delete cookies through your browser settings. Below are links to
        instructions for popular browsers:
      </p>
      <ul class="list-disc space-y-2 pl-5">
        <li><a href="https://support.google.com/chrome/answer/95647" class="text-brand-600 hover:underline" target="_blank" rel="noopener noreferrer">Google Chrome</a></li>
        <li><a href="https://support.mozilla.org/en-US/kb/clear-cookies-and-site-data-firefox" class="text-brand-600 hover:underline" target="_blank" rel="noopener noreferrer">Mozilla Firefox</a></li>
        <li><a href="https://support.apple.com/guide/safari/manage-cookies-websites-sfri11471/mac" class="text-brand-600 hover:underline" target="_blank" rel="noopener noreferrer">Apple Safari</a></li>
        <li><a href="https://support.microsoft.com/en-us/microsoft-edge/delete-cookies" class="text-brand-600 hover:underline" target="_blank" rel="noopener noreferrer">Microsoft Edge</a></li>
      </ul>
      <p class="mt-3">
        You can also opt out of Google Analytics tracking by installing the
        <a href="https://tools.google.com/dlpage/gaoptout" class="text-brand-600 hover:underline" target="_blank" rel="noopener noreferrer">Google Analytics Opt-out Browser Add-on</a>.
      </p>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">Impact of Disabling Cookies</h2>
      <p>
        Disabling essential cookies may cause the site to forget your language preference.
        Disabling analytics cookies will not affect site functionality but helps us keep
        StackPractices free and well-maintained by understanding what content is most useful.
      </p>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">Changes to This Policy</h2>
      <p>
        We may update this cookie policy from time to time to reflect changes in technology or legal
        requirements. Any changes will be posted on this page with an updated effective date.
      </p>

      <p class="mt-10 text-sm text-slate-500">Last updated: June 10, 2026</p>
    </div>
  </section>
</BaseLayout>
