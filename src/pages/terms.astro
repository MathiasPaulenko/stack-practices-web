---
import BaseLayout from '../layouts/BaseLayout.astro';
import { webPage, breadcrumbList } from '../lib/schema';

const jsonLd = [
  {
    ...webPage({
      name: 'Terms of Service',
      description: 'Terms of service for using StackPractices.',
      url: '/terms',
      locale: 'en',
    }),
    datePublished: '2026-06-10',
  },
  breadcrumbList([
    { name: 'Home', url: '/' },
    { name: 'Terms of Service', url: '/terms' },
  ]),
];
---

<BaseLayout
  title="Terms of Service"
  description="Terms of service for using StackPractices."
  path="/terms"
  keywords={['terms', 'tos', 'legal']}
  jsonLd={jsonLd}
>
  <!-- Subtle brand accent line -->
  <div class="h-[3px] bg-gradient-to-r from-brand-500 via-brand-400 to-transparent"></div>

  <!-- Header section -->
  <header class="border-b border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-3xl px-4 py-8 sm:px-6">
      <nav aria-label="Breadcrumb" class="text-sm text-slate-500">
        <a href="/" class="font-medium text-brand-600 hover:text-brand-700 hover:underline">Home</a>
        <span class="mx-2 text-slate-400">/</span>
        <span class="font-medium text-slate-800">Terms of Service</span>
      </nav>
      <h1 class="mt-4 text-3xl font-bold text-slate-900">Terms of Service</h1>
    </div>
  </header>

  <!-- Main content -->
  <section class="bg-white">
    <div class="prose prose-slate mx-auto max-w-3xl px-4 py-10 sm:px-6">
      <div class="space-y-6 text-slate-700">
      <p>
        By accessing and using StackPractices, you accept and agree to be bound by these terms and
        conditions. If you do not agree, please do not use this site.
      </p>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">Use of Content</h2>
      <p>
        All code snippets, patterns, and guides on StackPractices are provided for educational and
        reference purposes. Unless otherwise specified, you may copy, modify, and use code examples in
        your own projects — commercial or open source — without attribution.
      </p>
      <p>
        Content is offered "as is" without warranty of any kind, express or implied. We do not
        guarantee that code examples are error-free, secure, or suitable for your specific use case.
        Always review and test code before deploying it to production.
      </p>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">Acceptable Use</h2>
      <p>
        You agree not to use StackPractices to:
      </p>
      <ul class="list-disc space-y-2 pl-5">
        <li>Distribute malware, viruses, or any harmful code.</li>
        <li>Scrape, crawl, or automatically extract content in a way that degrades site performance.</li>
        <li>Impersonate any person or entity, or misrepresent your affiliation with any entity.</li>
        <li>Use the site for any unlawful purpose or in violation of any applicable laws.</li>
      </ul>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">Intellectual Property</h2>
      <p>
        The StackPractices name, logo, and original written content are the property of the site
        operator. Code examples are generally provided under permissive terms for reuse. Third-party
        trademarks, logos, and brand names referenced on this site belong to their respective owners.
      </p>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">External Links</h2>
      <p>
        StackPractices may contain links to external websites, including affiliate links. We are not
        responsible for the content, privacy practices, or availability of those sites. See our
        <a href="/affiliate-disclosure" class="text-brand-600 hover:underline">Affiliate Disclosure</a>
        for details on how we may earn commissions.
      </p>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">Disclaimer of Warranties</h2>
      <p>
        StackPractices is provided "as is" and "as available" without warranties of any kind. We do not
        warrant that the site will be uninterrupted, secure, or error-free. We are not liable for any
        direct, indirect, incidental, or consequential damages arising from your use of this site or
        its content.
      </p>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">Limitation of Liability</h2>
      <p>
        To the maximum extent permitted by law, StackPractices and its operator shall not be liable
        for any damages resulting from your use or inability to use the site, even if advised of the
        possibility of such damages. This includes loss of profits, data loss, or business interruption.
      </p>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">Indemnification</h2>
      <p>
        You agree to indemnify and hold harmless StackPractices and its operator from any claims,
        damages, or expenses arising from your use of the site, violation of these terms, or infringement
        of any third-party rights.
      </p>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">Governing Law and Jurisdiction</h2>
      <p>
        These terms are governed by the laws of the jurisdiction in which the site operator resides,
        without regard to conflict of law principles. Any disputes shall be resolved in the courts of
        that jurisdiction.
      </p>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">Changes to These Terms</h2>
      <p>
        We reserve the right to modify these terms at any time. Material changes will be posted on
        this page with an updated effective date. Continued use of the site after changes constitutes
        acceptance of the revised terms.
      </p>

      <p class="mt-10 text-sm text-slate-500">Last updated: June 10, 2026</p>
    </div>
  </section>
</BaseLayout>
