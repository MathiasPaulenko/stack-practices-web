---
import { getCollection } from 'astro:content';
import ListingPage from '../../components/ListingPage.astro';
import { isSpanish } from '../../lib/content';

const patterns = await getCollection('patterns', ({ id, data }) => !isSpanish(id) && !data.draft);
const entries = patterns.map((p) => ({
  title: p.data.title,
  description: p.data.description,
  href: `/patterns/${p.data.slug}`,
  difficulty: p.data.difficulty,
  tags: p.data.tags,
}));
---

<ListingPage
  heading="Patterns"
  description="Software design and architecture patterns explained with real, runnable examples."
  path="/patterns"
  entries={entries}
  keywords={['design patterns', 'software architecture', 'patterns examples']}
  contentType="patterns"
/>
