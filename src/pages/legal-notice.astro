---
import BaseLayout from '../layouts/BaseLayout.astro';
import { webPage, breadcrumbList } from '../lib/schema';

const jsonLd = [
  {
    ...webPage({
      name: 'Legal Notice',
      description: 'StackPractices legal notice and disclosure information.',
      url: '/legal-notice',
      locale: 'en',
    }),
    datePublished: '2026-06-10',
  },
  breadcrumbList([
    { name: 'Home', url: '/' },
    { name: 'Legal Notice', url: '/legal-notice' },
  ]),
];
---

<BaseLayout
  title="Legal Notice"
  description="StackPractices legal notice and disclosure information."
  path="/legal-notice"
  keywords={['legal notice', 'disclosure', 'liability']}
  jsonLd={jsonLd}
>
  <div class="h-[3px] bg-gradient-to-r from-brand-500 via-brand-400 to-transparent"></div>

  <header class="border-b border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-3xl px-4 py-8 sm:px-6">
      <nav aria-label="Breadcrumb" class="text-sm text-slate-500">
        <a href="/" class="font-medium text-brand-600 hover:text-brand-700 hover:underline">Home</a>
        <span class="mx-2 text-slate-400">/</span>
        <span class="font-medium text-slate-800">Legal Notice</span>
      </nav>
      <h1 class="mt-4 text-3xl font-bold text-slate-900">Legal Notice</h1>
    </div>
  </header>

  <section class="bg-white">
    <div class="prose prose-slate mx-auto max-w-3xl px-4 py-10 sm:px-6">
      <div class="space-y-6 text-slate-700">
        <p>
          This legal notice governs your use of the StackPractices website and services. By accessing
          this site, you acknowledge and agree to the provisions below.
        </p>

        <h2 class="mt-10 text-xl font-semibold text-slate-900">Site Owner and Contact</h2>
        <p>
          StackPractices is operated by an independent developer. For any inquiries, legal notices,
          or takedown requests, please contact us at
          <a href="mailto:mathias.paulenko@outlook.com" class="text-brand-600 hover:underline">mathias.paulenko@outlook.com</a>.
          We aim to respond to all communications within 5 business days.
        </p>

        <h2 class="mt-10 text-xl font-semibold text-slate-900">Liability Disclaimer</h2>
        <p>
          The content on StackPractices is provided for informational and educational purposes only.
          While we strive for accuracy and regularly review our content, we make no warranties,
          express or implied, regarding the completeness, reliability, currency, or suitability of the
          information for any particular purpose.
        </p>
        <p>
          Code recipes, patterns, and guides are offered as starting points and may require adaptation
          for your specific environment. Always review, test, and validate code before using it in
          production. We are not liable for any direct, indirect, incidental, or consequential damages
          arising from the use of this site or its content.
        </p>

        <h2 class="mt-10 text-xl font-semibold text-slate-900">External Links</h2>
        <p>
          StackPractices may contain links to third-party websites, including affiliate links.
          We are not responsible for the content, accuracy, privacy practices, or availability of
          those external sites. Visiting external links is at your own risk. See our
          <a href="/affiliate-disclosure/" class="text-brand-600 hover:underline">Affiliate Disclosure</a>
          for information on how we may earn commissions.
        </p>

        <h2 class="mt-10 text-xl font-semibold text-slate-900">Intellectual Property</h2>
        <p>
          All original written content, design, and branding on StackPractices is the property of
          the site operator unless otherwise stated. Code examples are generally provided for reuse
          under permissive terms. Third-party trademarks, logos, and brand names referenced on this
          site belong to their respective owners and are used for identification purposes only.
        </p>

        <h2 class="mt-10 text-xl font-semibold text-slate-900">DMCA and Copyright</h2>
        <p>
          We respect intellectual property rights. If you believe content on StackPractices infringes
          your copyright, please send a detailed takedown notice to
          <a href="mailto:mathias.paulenko@outlook.com" class="text-brand-600 hover:underline">mathias.paulenko@outlook.com</a>
          including: (1) your contact information, (2) identification of the copyrighted work,
          (3) identification of the infringing material, (4) a statement of good faith, and (5) your
          signature. We will investigate and respond promptly.
        </p>

        <h2 class="mt-10 text-xl font-semibold text-slate-900">Content Accuracy and Updates</h2>
        <p>
          Technology evolves rapidly. While we make reasonable efforts to keep content current,
          some information may become outdated. We encourage readers to verify details against
          official documentation of the technologies mentioned. Last updated dates are provided
          where applicable.
        </p>

        <h2 class="mt-10 text-xl font-semibold text-slate-900">Governing Law and Jurisdiction</h2>
        <p>
          This legal notice is governed by the laws applicable in the jurisdiction of the site
          operator, without regard to conflict of law principles. Any disputes arising from the use
          of this site shall be resolved in the competent courts of that jurisdiction.
        </p>

        <p class="mt-10 text-sm text-slate-500">Last updated: June 10, 2026</p>
      </div>
    </div>
  </section>
</BaseLayout>
