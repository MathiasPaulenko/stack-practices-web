---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, CONTENT_TYPES, TECHNOLOGIES } from '../config/site';
import { webPage } from '../lib/schema';
import { getCollection } from 'astro:content';
import { isSpanish } from '../lib/content';

const [recipes, patterns, docs, guides] = await Promise.all([
  getCollection('recipes', ({ id }) => !isSpanish(id)),
  getCollection('patterns', ({ id }) => !isSpanish(id)),
  getCollection('docs', ({ id }) => !isSpanish(id)),
  getCollection('guides', ({ id }) => !isSpanish(id)),
]);

const recipesCount = recipes.length;
const patternsCount = patterns.length;
const docsCount = docs.length;
const guidesCount = guides.length;
const topics = new Set<string>();
for (const col of [recipes, patterns, docs, guides]) {
  for (const entry of col) {
    entry.data.topics.forEach((t: string) => topics.add(t));
  }
}
const topicsCount = topics.size;

const jsonLd = [
  webPage({
    name: SITE.title,
    description: SITE.description,
    url: '/',
    locale: 'en',
  }),
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    url: SITE.url,
    potentialAction: {
      '@type': 'SearchAction',
      target: {
        '@type': 'EntryPoint',
        urlTemplate: `${SITE.url}/search?q={search_term_string}`,
      },
      'query-input': 'required name=search_term_string',
    },
  },
];

const concepts = [
  { label: 'API Design', slug: 'api' },
  { label: 'Authentication', slug: 'authentication' },
  { label: 'Architecture', slug: 'architecture' },
  { label: 'Performance', slug: 'performance' },
  { label: 'Testing', slug: 'testing' },
  { label: 'Security', slug: 'security' },
];
---

<BaseLayout
  title={SITE.title}
  description={SITE.description}
  path="/"
  ogType="website"
  keywords={['code recipes', 'design patterns', 'software engineering', 'developer documentation']}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="hero-animated-bg bg-slate-900">
    <span class="hero-dot" aria-hidden="true"></span>
    <span class="hero-dot" aria-hidden="true"></span>
    <span class="hero-dot" aria-hidden="true"></span>
    <span class="hero-dot" aria-hidden="true"></span>
    <span class="hero-dot" aria-hidden="true"></span>
    <span class="hero-dot" aria-hidden="true"></span>
    <span class="hero-dot" aria-hidden="true"></span>
    <span class="hero-dot" aria-hidden="true"></span>
    <span class="hero-code-symbol" aria-hidden="true">{ }</span>
    <span class="hero-code-symbol" aria-hidden="true">&lt;/&gt;</span>
    <span class="hero-code-symbol" aria-hidden="true">//</span>
    <span class="hero-code-symbol" aria-hidden="true">[ ]</span>
    <span class="hero-code-symbol" aria-hidden="true">&&</span>
    <span class="hero-code-symbol" aria-hidden="true">;;</span>
    <div class="relative z-10 mx-auto max-w-6xl px-4 py-20 text-center sm:px-6 sm:py-28">
      <h1 class="mx-auto max-w-3xl text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
        Practical software engineering knowledge, ready to reuse
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-300">
        Find real-world code recipes, design patterns, and reusable documentation across
        Python, Java, JavaScript, SQL, and more.
      </p>
      <div class="relative z-10 mx-auto mt-10 flex flex-wrap justify-center gap-8 sm:gap-12">
        <div class="text-center">
          <div class="text-2xl font-bold text-white">{recipesCount}</div>
          <div class="mt-1 text-xs font-medium uppercase tracking-wider text-slate-400">Recipes</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-white">{patternsCount}</div>
          <div class="mt-1 text-xs font-medium uppercase tracking-wider text-slate-400">Patterns</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-white">{docsCount}</div>
          <div class="mt-1 text-xs font-medium uppercase tracking-wider text-slate-400">Docs</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-white">{guidesCount}</div>
          <div class="mt-1 text-xs font-medium uppercase tracking-wider text-slate-400">Guides</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-white">{topicsCount}</div>
          <div class="mt-1 text-xs font-medium uppercase tracking-wider text-slate-400">Topics</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Browse by Type -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <h2 class="text-2xl font-bold text-slate-900">Browse by type</h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        CONTENT_TYPES.map((type) => (
          <a
            href={`/${type.slug}`}
            class="group rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-brand-400 hover:shadow-lg"
          >
            <h3 class="text-lg font-semibold text-slate-900 group-hover:text-brand-600">{type.label}</h3>
            <p class="mt-2 text-sm text-slate-600">{type.description}</p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Browse by Technology -->
  <section class="border-t border-slate-200 bg-slate-100">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <h2 class="text-2xl font-bold text-slate-900">Browse by technology</h2>
      <div class="mt-8 flex flex-wrap gap-3">
        {
          TECHNOLOGIES.map((tech) => (
            <a
              href={`/topics?tech=${tech}`}
              class="rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-semibold capitalize text-slate-700 shadow-sm transition hover:border-brand-400 hover:text-brand-600"
            >
              {tech}
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Browse by Concept -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <h2 class="text-2xl font-bold text-slate-900">Browse by concept</h2>
    <div class="mt-8 flex flex-wrap gap-3">
      {
        concepts.map((concept) => (
          <a
            href={`/topics/${concept.slug}`}
            class="rounded-full bg-brand-100 px-4 py-2 text-sm font-semibold text-brand-800 transition hover:bg-brand-200 hover:text-brand-900"
          >
            {concept.label}
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
