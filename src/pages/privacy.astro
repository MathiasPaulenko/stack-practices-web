---
import BaseLayout from '../layouts/BaseLayout.astro';
import { webPage, breadcrumbList } from '../lib/schema';

const jsonLd = [
  {
    ...webPage({
      name: 'Privacy Policy',
      description: 'StackPractices privacy policy: how we handle data and cookies.',
      url: '/privacy',
      locale: 'en',
    }),
    datePublished: '2026-06-10',
  },
  breadcrumbList([
    { name: 'Home', url: '/' },
    { name: 'Privacy Policy', url: '/privacy' },
  ]),
];
---

<BaseLayout
  title="Privacy Policy"
  description="StackPractices privacy policy: how we handle data and cookies."
  path="/privacy"
  keywords={['privacy', 'cookies', 'data']}
  jsonLd={jsonLd}
>
  <!-- Subtle brand accent line -->
  <div class="h-[3px] bg-gradient-to-r from-brand-500 via-brand-400 to-transparent"></div>

  <!-- Header section -->
  <header class="border-b border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-3xl px-4 py-8 sm:px-6">
      <nav aria-label="Breadcrumb" class="text-sm text-slate-500">
        <a href="/" class="font-medium text-brand-600 hover:text-brand-700 hover:underline">Home</a>
        <span class="mx-2 text-slate-400">/</span>
        <span class="font-medium text-slate-800">Privacy Policy</span>
      </nav>
      <h1 class="mt-4 text-3xl font-bold text-slate-900">Privacy Policy</h1>
    </div>
  </header>

  <!-- Main content -->
  <section class="bg-white">
    <div class="prose prose-slate mx-auto max-w-3xl px-4 py-10 sm:px-6">
      <div class="space-y-6 text-slate-700">
      <p>
        StackPractices respects your privacy. This policy explains what data we collect, how we use it,
        how we protect it, and your rights regarding that data.
      </p>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">Information We Collect</h2>
      <p>
        StackPractices is a static site with no backend database. We do not collect, store, or process
        personal data directly on our servers. However, we use third-party services that may collect
        anonymous usage data to help us improve the site:
      </p>
      <ul class="list-disc space-y-2 pl-5">
        <li>
          <strong>Google Analytics</strong> — anonymous page views, session duration, and interactions
          to understand content popularity and user experience. Data is aggregated and does not
          personally identify you. You can opt out via our cookie consent banner.
        </li>
        <li>
          <strong>Pagefind</strong> — local search runs entirely in your browser. No search queries or
          data are sent to our servers or any third party.
        </li>
        <li>
          <strong>Contact Form (Formspree)</strong> — when you submit a message through our contact
          form, Formspree processes your name, email, and message on our behalf. See Formspree's
          privacy policy for details on how they handle this data.
        </li>
        <li>
          <strong>Ko-fi</strong> — donation buttons link to Ko-fi's platform. Ko-fi handles all
          payment processing independently. We do not receive or store any payment information.
        </li>
      </ul>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">How We Use Your Information</h2>
      <p>
        Any data collected is used solely for the following purposes:
      </p>
      <ul class="list-disc space-y-2 pl-5">
        <li>To understand which content is most helpful and improve our resources.</li>
        <li>To respond to messages sent through the contact form.</li>
        <li>To maintain site security and diagnose technical issues.</li>
      </ul>
      <p>
        We do <strong>not</strong> sell, rent, or share your personal data with advertisers or data brokers.
      </p>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">Cookies and Tracking</h2>
      <p>
        We use essential cookies (for language preference and cookie consent state) and analytics
        cookies (Google Analytics, only with your consent). You can manage or disable cookies through
        your browser settings or via our cookie consent banner. For more details, see our
        <a href="/cookies/" class="text-brand-600 hover:underline">Cookie Policy</a>.
      </p>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">Data Security</h2>
      <p>
        Since StackPractices is a static site, there is no user database to breach. Analytics data
        is handled by Google under their security standards. Contact form submissions are processed by
        Formspree using industry-standard encryption (TLS/SSL).
      </p>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">Data Retention</h2>
      <p>
        Google Analytics retains aggregated data according to Google's data retention policies
        (typically 2–14 months depending on settings). Contact form messages are retained in
        Formspree's systems until manually deleted by us.
      </p>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">Your Rights (GDPR / CCPA)</h2>
      <p>
        Depending on your jurisdiction, you may have the right to:
      </p>
      <ul class="list-disc space-y-2 pl-5">
        <li><strong>Access</strong> — request a copy of any personal data we hold about you.</li>
        <li><strong>Correction</strong> — request that inaccurate data be corrected.</li>
        <li><strong>Deletion</strong> — request deletion of your personal data.</li>
        <li><strong>Objection</strong> — object to the processing of your data for analytics.</li>
        <li><strong>Portability</strong> — receive your data in a structured, machine-readable format.</li>
      </ul>
      <p class="mt-3">
        Since we do not store personal data directly, most requests relate to third-party services.
        To exercise your rights, <a href="/contact/" class="text-brand-600 hover:underline">contact us</a>
        and we will assist you in directing your request to the appropriate provider.
      </p>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">Children's Privacy</h2>
      <p>
        StackPractices does not knowingly collect data from children under 13. If you believe a child
        has provided personal information through our contact form, please
        <a href="/contact/" class="text-brand-600 hover:underline">contact us</a> and we will promptly
        delete such information.
      </p>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">Third-Party Services</h2>
      <p>
        This site uses services provided by Google (Analytics), Formspree (contact forms), and Ko-fi
        (donations). Each has its own privacy policy. We encourage you to review them:
      </p>
      <ul class="list-disc space-y-2 pl-5">
        <li><a href="https://policies.google.com/privacy" class="text-brand-600 hover:underline" target="_blank" rel="noopener noreferrer">Google Privacy Policy</a></li>
        <li><a href="https://formspree.io/legal/privacy-policy" class="text-brand-600 hover:underline" target="_blank" rel="noopener noreferrer">Formspree Privacy Policy</a></li>
        <li><a href="https://ko-fi.com/privacy" class="text-brand-600 hover:underline" target="_blank" rel="noopener noreferrer">Ko-fi Privacy Policy</a></li>
      </ul>

      <h2 class="mt-10 text-xl font-semibold text-slate-900">Changes to This Policy</h2>
      <p>
        We may update this privacy policy from time to time to reflect changes in our practices or
        legal requirements. Changes will be posted on this page with an updated effective date.
        Significant changes will be announced via a site notice.
      </p>

      <p class="mt-10 text-sm text-slate-500">Last updated: June 10, 2026</p>
    </div>
  </section>
</BaseLayout>
