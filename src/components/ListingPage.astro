---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from './ContentCard.astro';
import { collectionPage, breadcrumbList } from '../lib/schema';
import type { Locale } from '../config/site';

export interface ListingEntry {
  title: string;
  description: string;
  href: string;
  difficulty?: string;
  tags?: string[];
}

export interface Props {
  heading: string;
  description: string;
  path: string;
  entries: ListingEntry[];
  keywords?: string[];
  locale?: Locale;
  contentType?: string;
  hasAlternate?: boolean;
}

const { heading, description, path, entries, keywords = [], locale = 'en', contentType, hasAlternate = true } = Astro.props;

const homeHref = locale === 'es' ? '/es' : '/';
const homeLabel = locale === 'es' ? 'Inicio' : 'Home';

const jsonLd = [
  collectionPage({
    name: heading,
    description,
    url: path,
    locale,
    items: entries.map((e: ListingEntry) => ({ name: e.title, url: e.href })),
  }),
  breadcrumbList([
    { name: homeLabel, url: homeHref },
    { name: heading, url: path },
  ]),
];
---

<BaseLayout title={heading} description={description} path={path} locale={locale} keywords={keywords} jsonLd={jsonLd} hasAlternate={hasAlternate}>
  <div data-pagefind-filter={contentType ? `contentType[${contentType}]` : undefined}>
  <!-- Mini hero: breadcrumb, title, description, search -->
  <section class="border-b border-slate-800 bg-slate-900">
    <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
      <nav aria-label="Breadcrumb" class="text-sm text-slate-400">
        <a href={homeHref} class="font-medium text-brand-400 hover:text-brand-300">{homeLabel}</a>
        <span class="mx-2 text-slate-600">/</span>
        <span class="font-medium text-slate-300">{heading}</span>
      </nav>

      <h1 class="mt-4 text-3xl font-bold text-white">{heading}</h1>
      <p class="mt-2 max-w-2xl text-slate-300">{description}</p>

      {
        entries.length > 0 && (
          <div class="mt-6">
            <div class="relative max-w-md">
              <input
                type="text"
                id="listing-search"
                placeholder={locale === 'es' ? 'Buscar...' : 'Search...'}
                class="w-full rounded-lg border border-slate-600 bg-slate-800 py-2.5 pl-10 pr-4 text-sm text-white placeholder:text-slate-400 focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500"
              />
              <svg
                class="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.3-4.3"></path>
              </svg>
            </div>
            <p id="listing-count" class="mt-2 text-sm text-slate-400">
              {entries.length} {locale === 'es' ? 'resultados' : 'results'}
            </p>
          </div>
        )
      }
    </div>
  </section>

  <!-- Card grid -->
  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
      {
        entries.length > 0 ? (
          <>
            <div id="listing-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {entries.map((entry: ListingEntry) => (
                <ContentCard
                  title={entry.title}
                  description={entry.description}
                  href={entry.href}
                  difficulty={entry.difficulty}
                  tags={entry.tags}
                  locale={locale}
                />
              ))}
            </div>

            <div id="listing-empty" class="hidden rounded-xl border border-dashed border-slate-300 bg-slate-100 p-12 text-center">
              <p class="text-slate-600">{locale === 'es' ? 'No se encontraron resultados.' : 'No results found.'}</p>
            </div>
          </>
        ) : (
          <div class="rounded-xl border border-dashed border-slate-300 bg-slate-100 p-12 text-center">
            <p class="text-slate-600">{locale === 'es' ? 'Aún no hay contenido publicado. Vuelve pronto.' : 'No content published yet. Check back soon.'}</p>
          </div>
        )
      }
    </div>
  </section>

  <script is:inline>
    (function () {
      const input = document.getElementById('listing-search');
      const grid = document.getElementById('listing-grid');
      const count = document.getElementById('listing-count');
      const empty = document.getElementById('listing-empty');
      if (!input || !grid || !count || !empty) return;

      const cards = grid.querySelectorAll('[data-search]');
      const isEs = count.textContent.includes('resultados');

      function update() {
        const query = input.value.trim().toLowerCase();
        const terms = query.split(/\s+/).filter(Boolean);
        let visible = 0;

        cards.forEach((card) => {
          const index = (card.getAttribute('data-search') || '').toLowerCase();
          const match = terms.every((term) => index.includes(term));
          card.style.display = match ? '' : 'none';
          if (match) visible++;
        });

        count.textContent = visible + ' ' + (isEs ? 'resultado' + (visible === 1 ? '' : 's') : 'result' + (visible === 1 ? '' : 's'));

        if (visible === 0) {
          grid.classList.add('hidden');
          empty.classList.remove('hidden');
        } else {
          grid.classList.remove('hidden');
          empty.classList.add('hidden');
        }
      }

      input.addEventListener('input', update);
    })();
  </script>
  </div>
</BaseLayout>
