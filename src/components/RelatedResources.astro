---
export interface RelatedItem {
  title: string;
  description: string;
  href: string;
  contentType: string;
}

export interface Props {
  items: RelatedItem[];
  heading?: string;
}

const { items, heading = 'Related Resources' } = Astro.props;

const typeLabel: Record<string, string> = {
  recipes: 'Recipe',
  patterns: 'Pattern',
  docs: 'Doc',
  guides: 'Guide',
};
---

{
  items.length > 0 && (
    <div aria-labelledby="related-heading">
      <h2 id="related-heading" class="text-lg font-bold text-slate-900">{heading}</h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {items.map((item) => (
          <a
            href={item.href}
            class="group rounded-xl border border-slate-200 bg-white p-5 transition hover:border-brand-300 hover:shadow-md"
          >
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">
              {typeLabel[item.contentType] ?? item.contentType}
            </span>
            <h3 class="mt-1 font-semibold text-slate-900 group-hover:text-brand-700">{item.title}</h3>
            <p class="mt-1 line-clamp-2 text-sm text-slate-500">{item.description}</p>
          </a>
        ))}
      </div>
    </div>
  )
}
