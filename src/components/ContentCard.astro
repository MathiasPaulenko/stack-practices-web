---
export interface Props {
  title: string;
  description: string;
  href: string;
  difficulty?: string;
  tags?: string[];
  locale?: 'en' | 'es';
}

const { title, description, href, difficulty, tags = [], locale = 'en' } = Astro.props;

const searchIndex = [title, description, difficulty, ...tags].filter(Boolean).join(' ').toLowerCase();
const tagPrefix = locale === 'es' ? '/es' : '';

const difficultyColor: Record<string, string> = {
  beginner: 'bg-green-100 text-green-700',
  intermediate: 'bg-amber-100 text-amber-700',
  advanced: 'bg-red-100 text-red-700',
};
---

<div
  data-search={searchIndex}
  class="group flex flex-col rounded-xl border border-slate-200 bg-white p-6 transition hover:border-brand-300 hover:shadow-md"
>
  <div class="flex items-center gap-2">
    {
      difficulty && (
        <span class:list={['rounded-full px-2.5 py-0.5 text-xs font-semibold capitalize', difficultyColor[difficulty] ?? 'bg-slate-100 text-slate-700']}>
          {difficulty}
        </span>
      )
    }
  </div>
  <a href={href} class="block">
    <h3 class="mt-3 text-lg font-semibold text-slate-900 group-hover:text-brand-600">{title}</h3>
  </a>
  <p class="mt-2 flex-1 text-sm text-slate-600">{description}</p>
  {
    tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-1.5">
        {tags.slice(0, 4).map((tag: string) => (
          <a
            href={`${tagPrefix}/tags/${tag}`}
            class="rounded bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-700 transition hover:bg-brand-100 hover:text-brand-700"
          >
            {tag}
          </a>
        ))}
      </div>
    )
  }
</div>
