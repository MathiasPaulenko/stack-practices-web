---
import { SITE, FOOTER_NAV, type Locale } from '../../config/site';

export interface Props {
  locale?: Locale;
}

const { locale = SITE.defaultLocale } = Astro.props;
const prefix = locale === 'es' ? '/es' : '';
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-700 bg-slate-900" data-pagefind-ignore>
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5">
      <div>
        <a href={`${prefix}/`} class="flex items-center gap-2 font-bold text-white">
          <span class="grid h-8 w-8 place-items-center rounded-lg bg-brand-500 font-mono text-sm text-white">SP</span>
          <span>{SITE.name}</span>
        </a>
        <p class="mt-3 text-sm text-slate-400">
          {locale === 'es'
            ? 'Recetas de código, patrones de diseño y documentación de ingeniería de software.'
            : 'Practical code recipes, design patterns, and software engineering docs.'}
        </p>
        <a
          href="https://ko-fi.com/C6E4212B3X"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-3 inline-block transition hover:scale-105 hover:brightness-110"
          aria-label={locale === 'es' ? 'Apóyanos en Ko-fi' : 'Support us on Ko-fi'}
        >
          <img
            src="https://storage.ko-fi.com/cdn/kofi3.png?v=6"
            alt={locale === 'es' ? 'Apóyanos en ko-fi.com' : 'Buy Me a Coffee at ko-fi.com'}
            class="block h-10"
            loading="lazy"
          />
        </a>
      </div>

      <div>
        <h2 class="text-sm font-semibold text-white">Content</h2>
        <ul class="mt-3 space-y-2">
          {FOOTER_NAV.content.map((item) => (
            <li>
              <a href={`${prefix}${item.href}`} class="text-sm text-slate-400 hover:text-brand-400">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h2 class="text-sm font-semibold text-white">Site</h2>
        <ul class="mt-3 space-y-2">
          {FOOTER_NAV.site.map((item) => (
            <li>
              <a href={`${prefix}${item.href}`} class="text-sm text-slate-400 hover:text-brand-400">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h2 class="text-sm font-semibold text-white">Author</h2>
        <ul class="mt-3 space-y-2">
          <li>
            <a href="https://mathiaspaulenko.com" target="_blank" rel="noopener noreferrer" class="text-sm text-slate-400 hover:text-brand-400 flex items-center gap-1.5">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
              mathiaspaulenko.com
            </a>
          </li>
          <li>
            <a href="https://github.com/MathiasPaulenko" target="_blank" rel="noopener noreferrer" class="text-sm text-slate-400 hover:text-brand-400 flex items-center gap-1.5">
              <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              GitHub
            </a>
          </li>
          <li>
            <a href="https://cn.linkedin.com/in/mathias-paulenko-echeverz" target="_blank" rel="noopener noreferrer" class="text-sm text-slate-400 hover:text-brand-400 flex items-center gap-1.5">
              <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </a>
          </li>
          <li>
            <a href="mailto:mathias.paulenko@outlook.com" class="text-sm text-slate-400 hover:text-brand-400 flex items-center gap-1.5">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              mathias.paulenko@outlook.com
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h2 class="text-sm font-semibold text-white">Legal</h2>
        <ul class="mt-3 space-y-2">
          {FOOTER_NAV.legal.map((item) => (
            <li>
              <a href={`${prefix}${item.href}`} class="text-sm text-slate-400 hover:text-brand-400">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-center justify-between gap-4 border-t border-slate-700 pt-6 sm:flex-row">
      <p class="text-sm text-slate-500">
        &copy; {year} {SITE.name}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
