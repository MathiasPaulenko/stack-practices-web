---
import { SITE, MAIN_NAV, type Locale } from '../../config/site';

export interface Props {
  locale?: Locale;
}

const { locale = SITE.defaultLocale } = Astro.props;
const prefix = locale === 'es' ? '/es' : '';
const navPrefix = locale === 'es' ? '/es/' : '/';
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-slate-700 bg-slate-900/95 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-4 sm:px-6">
    <a href={`${prefix}/`} class="flex items-center gap-2 font-bold text-white">
      <span class="grid h-10 w-10 shrink-0 place-items-center rounded-lg overflow-hidden">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="3 5 27 22" aria-hidden="true">
          <defs>
            <linearGradient id="logo-bg" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="#3b82f6"/>
              <stop offset="1" stop-color="#1d4ed8"/>
            </linearGradient>
          </defs>
          <rect width="32" height="32" rx="7" fill="url(#logo-bg)"/>
          <path d="M10 7C8.5 7 7.5 8 7.5 10v3c0 1.5-1 2.5-2.5 3 1.5.5 2.5 1.5 2.5 3v3c0 2 1 3 2.5 3" fill="none" stroke="#fff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M22 7c1.5 0 2.5 1 2.5 3v3c0 1.5 1 2.5 2.5 3-1.5.5-2.5 1.5-2.5 3v3c0 2-1 3-2.5 3" fill="none" stroke="#fff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          <rect x="12" y="11" width="8" height="2" rx="1" fill="#fff" opacity="0.5"/>
          <rect x="11" y="15" width="10" height="2" rx="1" fill="#fff" opacity="0.75"/>
          <rect x="10" y="19" width="12" height="2" rx="1" fill="#fff"/>
        </svg>
      </span>
      <span class="text-xl">{SITE.name}</span>
    </a>

    <nav aria-label="Main navigation" class="hidden items-center gap-1 md:flex">
      {
        MAIN_NAV.map((item) => {
          const href = `${prefix}${item.href}`;
          const isActive = currentPath.startsWith(href);
          return (
            <a
              href={href}
              class:list={[
                'rounded-md px-3 py-2 text-sm font-medium transition-colors',
                isActive
                  ? 'bg-brand-500/20 text-brand-300'
                  : 'text-slate-300 hover:bg-slate-800 hover:text-white',
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={`${prefix}/search/`}
        class="rounded-md p-2 text-slate-300 hover:bg-slate-800 hover:text-white"
        aria-label="Search"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
      </a>
      <a
        href={locale === 'es' ? currentPath.replace(/^\/es/, '') || '/' : `/es${currentPath.endsWith('/') ? currentPath : `${currentPath}/`}`}
        class="rounded-md border border-slate-600 px-2.5 py-1.5 text-xs font-semibold text-slate-300 hover:bg-slate-800 hover:text-white"
        aria-label="Switch language"
      >
        {locale === 'es' ? 'EN' : 'ES'}
      </a>
    </div>
  </div>
</header>
